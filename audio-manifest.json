            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-016",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-016.mp3",
            "path": "public/audio/ui/phrase-016.mp3",
            "text": "انطلق مع كريم",
            "ttsText": "اِنْطَلِقْ مَعَ كَرِيم",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-017",
