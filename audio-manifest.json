            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-011",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-011.mp3",
            "path": "public/audio/ui/phrase-011.mp3",
            "text": "العودة للرئيسية",
            "ttsText": "الْعَوْدَةُ لِلرَّئِيسِيَّة",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-012",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-012.mp3",
            "path": "public/audio/ui/phrase-012.mp3",
