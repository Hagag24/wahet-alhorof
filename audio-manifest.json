        {
            "id": "story-01-scene-01",
            "kind": "storyScene",
            "group": "story-01",
            "scene": 1,
            "fileName": "scene-1-1.mp3",
            "path": "public/audio/stories/scene-1-1.mp3",
            "text": "اسمي مريم وعمري ست سنوات، وأخي يوسف عمره تسع سنوات.",
            "ttsText": "اِسْمِي مَرْيَمُ، وَعُمْرِي سِتُّ سَنَوَاتٍ، وَأَخِي يُوسُفُ عُمْرُهُ تِسْعُ سَنَوَاتٍ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-01-scene-02",
            "kind": "storyScene",
            "group": "story-01",
            "scene": 2,
            "fileName": "scene-1-2.mp3",
            "path": "public/audio/stories/scene-1-2.mp3",
            "text": "كان يوسف دائمًا يساعد أمي وأبي في أشياء عديدة بالبيت.",
            "ttsText": "كَانَ يُوسُفُ دَائِمًا يُسَاعِدُ أُمِّي وَأَبِي فِي أَشْيَاءَ عَدِيدَةٍ بِالْبَيْتِ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-01-scene-03",
            "kind": "storyScene",
            "group": "story-01",
            "scene": 3,
            "fileName": "scene-1-3.mp3",
            "path": "public/audio/stories/scene-1-3.mp3",
            "text": "كشراء الأكل من المتجر القريب، والاعتناء بأشجار الحديقة.",
            "ttsText": "كَشِرَاءِ الْأَكْلِ مِنَ الْمَتْجَرِ الْقَرِيبِ، وَالِاعْتِنَاءِ بِأَشْجَارِ الْحَدِيقَةِ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-01-scene-04",
            "kind": "storyScene",
            "group": "story-01",
            "scene": 4,
            "fileName": "scene-1-4.mp3",
            "path": "public/audio/stories/scene-1-4.mp3",
            "text": "كنت دائمًا أفكر في أن أتعلم أشياء لأساعد بها أمي وأبي في البيت أيضًا.",
            "ttsText": "كُنْتُ دَائِمًا أُفَكِّرُ فِي أَنْ أَتَعَلَّمَ أَشْيَاءَ لِأُسَاعِدَ بِهَا أُمِّي وَأَبِي فِي الْبَيْتِ أَيْضًا.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-01-scene-05",
            "kind": "storyScene",
            "group": "story-01",
            "scene": 5,
            "fileName": "scene-1-5.mp3",
            "path": "public/audio/stories/scene-1-5.mp3",
            "text": "وفي يوم من الأيام رأيت يوسف وهو يركب دراجته بسرعة ومهارة وهو ذاهب إلى المتجر ليشتري طلبات البيت.",
            "ttsText": "وَفِي يَوْمٍ مِنَ الْأَيَّامِ، رَأَيْتُ يُوسُفَ وَهُوَ يَرْكَبُ دَرَّاجَتَهُ بِسُرْعَةٍ وَمَهَارَةٍ، وَهُوَ ذَاهِبٌ إِلَى الْمَتْجَرِ لِيَشْتَرِيَ طَلَبَاتِ الْبَيْتِ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-01-scene-06",
            "kind": "storyScene",
            "group": "story-01",
            "scene": 6,
            "fileName": "scene-1-6.mp3",
            "path": "public/audio/stories/scene-1-6.mp3",
            "text": "شعرت بالحزن؛ فأنا – أيضًا – أريد أن أساعد أمي وأبي.",
            "ttsText": "شَعَرْتُ بِالْحُزْنِ؛ فَأَنَا – أَيْضًا – أُرِيدُ أَنْ أُسَاعِدَ أُمِّي وَأَبِي.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-02-scene-01",
            "kind": "storyScene",
            "group": "story-02",
            "scene": 1,
            "fileName": "scene-2-1.mp3",
            "path": "public/audio/stories/scene-2-1.mp3",
            "text": "أميرة فتاة صغيرة تعيش مع أسرتها السعيدة.",
            "ttsText": "أَمِيرَةُ، فَتَاةٌ صَغِيرَةٌ، تَعِيشُ مَعَ أُسْرَتِهَا السَّعِيدَةِ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-02-scene-02",
            "kind": "storyScene",
            "group": "story-02",
            "scene": 2,
            "fileName": "scene-2-2.mp3",
            "path": "public/audio/stories/scene-2-2.mp3",
            "text": "في كل صباح، تستيقظ أميرة وتساعد أمها في ترتيب البيت.",
            "ttsText": "فِي كُلِّ صَبَاحٍ، تَسْتَيْقِظُ أَمِيرَةُ، وَتُسَاعِدُ أُمَّهَا فِي تَرْتِيبِ الْبَيْتِ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-02-scene-03",
            "kind": "storyScene",
            "group": "story-02",
            "scene": 3,
            "fileName": "scene-2-3.mp3",
            "path": "public/audio/stories/scene-2-3.mp3",
            "text": "أبوها يحب أن يلعب معها في الحديقة.",
            "ttsText": "أَبُوهَا يُحِبُّ أَنْ يَلْعَبَ مَعَهَا فِي الْحَدِيقَةِ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-02-scene-04",
            "kind": "storyScene",
            "group": "story-02",
            "scene": 4,
            "fileName": "scene-2-4.mp3",
            "path": "public/audio/stories/scene-2-4.mp3",
            "text": "تحب أميرة أسرتها كثيرًا، وتشعر بالسعادة عندما يجتمعون معًا.",
            "ttsText": "تُحِبُّ أَمِيرَةُ أُسْرَتَهَا كَثِيرًا، وَتَشْعُرُ بِالسَّعَادَةِ عِنْدَمَا يَجْتَمِعُونَ مَعًا.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-02-scene-05",
            "kind": "storyScene",
            "group": "story-02",
            "scene": 5,
            "fileName": "scene-2-5.mp3",
            "path": "public/audio/stories/scene-2-5.mp3",
            "text": "في يوم الإجازة، ذهبت الأسرة إلى الحديقة الكبيرة.",
            "ttsText": "فِي يَوْمِ الْإِجَازَةِ، ذَهَبَتِ الْأُسْرَةُ إِلَى الْحَدِيقَةِ الْكَبِيرَةِ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-02-scene-06",
            "kind": "storyScene",
            "group": "story-02",
            "scene": 6,
            "fileName": "scene-2-6.mp3",
            "path": "public/audio/stories/scene-2-6.mp3",
            "text": "لعبت أميرة وضحكت كثيرًا. قالت: أنا أحب أسرتي!",
            "ttsText": "لَعِبَتْ أَمِيرَةُ وَضَحِكَتْ كَثِيرًا. قَالَتْ: أَنَا أُحِبُّ أُسْرَتِي!",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "story-03-scene-01",
            "kind": "storyScene",
            "group": "story-03",
            "scene": 1,
            "fileName": "scene-3-1.mp3",
            "path": "public/audio/stories/scene-3-1.mp3",
            "text": "سامي يحب الحيوانات، ويحب جمع صورها.",
            "ttsText": "سَامِي يُحِبُّ الْحَيَوَانَاتِ، وَيُحِبُّ جَمْعَ صُوَرِهَا.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-03-scene-02",
            "kind": "storyScene",
            "group": "story-03",
            "scene": 2,
            "fileName": "scene-3-2.mp3",
            "path": "public/audio/stories/scene-3-2.mp3",
            "text": "في يوم الإجازة، جهز الأب فيديو عن حيوانات الغابة.",
            "ttsText": "فِي يَوْمِ الْإِجَازَةِ، جَهَّزَ الْأَبُ فِيدْيُو عَنْ حَيَوَانَاتِ الْغَابَةِ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-03-scene-03",
            "kind": "storyScene",
            "group": "story-03",
            "scene": 3,
            "fileName": "scene-3-3.mp3",
            "path": "public/audio/stories/scene-3-3.mp3",
            "text": "شاهد سامي أسدًا يستريح تحت شجرة، فقال الأب: الأسد هو ملك الغابة، وهو حيوان قوي.",
            "ttsText": "شَاهَدَ سَامِي أَسَدًا يَسْتَرِيحُ تَحْتَ شَجَرَةٍ، فَقَالَ الْأَبُ: الْأَسَدُ هُوَ مَلِكُ الْغَابَةِ، وَهُوَ حَيَوَانٌ قَوِيٌّ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-03-scene-04",
            "kind": "storyScene",
            "group": "story-03",
            "scene": 4,
            "fileName": "scene-3-4.mp3",
            "path": "public/audio/stories/scene-3-4.mp3",
            "text": "وسمع البلبل يغني بصوته الجميل، فشعر سامي بالسعادة.",
            "ttsText": "وَسَمِعَ الْبُلْبُلَ يُغَنِّي بِصَوْتِهِ الْجَمِيلِ، فَشَعَرَ سَامِي بِالسَّعَادَةِ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-03-scene-05",
            "kind": "storyScene",
            "group": "story-03",
            "scene": 5,
            "fileName": "scene-3-5.mp3",
            "path": "public/audio/stories/scene-3-5.mp3",
            "text": "ومن خلف الشجرة، خرج الأرنب يجري، فقال سامي: الأرنب سريع جدًا.",
            "ttsText": "وَمِنْ خَلْفِ الشَّجَرَةِ، خَرَجَ الْأَرْنَبُ يَجْرِي، فَقَالَ سَامِي: الْأَرْنَبُ سَرِيعٌ جِدًّا.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-03-scene-06",
            "kind": "storyScene",
            "group": "story-03",
            "scene": 6,
            "fileName": "scene-3-6.mp3",
            "path": "public/audio/stories/scene-3-6.mp3",
            "text": "وشاهد نملة تجر حبة كبيرة، فصاح: انظر يا أبي، النملة قوية جدًا.",
            "ttsText": "وَشَاهَدَ نَمْلَةً تَجُرُّ حَبَّةً كَبِيرَةً، فَصَاحَ: اُنْظُرْ يَا أَبِي، النَّمْلَةُ قَوِيَّةٌ جِدًّا.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-03-scene-07",
            "kind": "storyScene",
            "group": "story-03",
            "scene": 7,
            "fileName": "scene-3-7.mp3",
            "path": "public/audio/stories/scene-3-7.mp3",
            "text": "قال سامي: تعلمت الكثير عن عالم الحيوان، فهو عالم عجيب.",
            "ttsText": "قَالَ سَامِي: تَعَلَّمْتُ الْكَثِيرَ عَنْ عَالَمِ الْحَيَوَانِ، فَهُوَ عَالَمٌ عَجِيبٌ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-01",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 1,
            "fileName": "scene-4-1.mp3",
            "path": "public/audio/stories/scene-4-1.mp3",
            "text": "استيقظ كريم من نومه سعيدًا، لبس ملابسه، وحمل حقيبته.",
            "ttsText": "اِسْتَيْقَظَ كَرِيمُ مِنْ نَوْمِهِ سَعِيدًا، لَبِسَ مَلَابِسَهُ، وَحَمَلَ حَقِيبَتَهُ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-02",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 2,
            "fileName": "scene-4-2.mp3",
            "path": "public/audio/stories/scene-4-2.mp3",
            "text": "وعندما وصل إلى المدرسة، استقبلته المعلمة بابتسامة.",
            "ttsText": "وَعِنْدَمَا وَصَلَ إِلَى الْمَدْرَسَةِ، اِسْتَقْبَلَتْهُ الْمُعَلِّمَةُ بِابْتِسَامَةٍ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-03",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 3,
            "fileName": "scene-4-3.mp3",
            "path": "public/audio/stories/scene-4-3.mp3",
            "text": "في حصة الرسم أخرج كريم القلم الرصاص وألوانه الجميلة.",
            "ttsText": "فِي حِصَّةِ الرَّسْمِ، أَخْرَجَ كَرِيمُ الْقَلَمَ الرَّصَاصَ وَأَلْوَانَهُ الْجَمِيلَةَ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-04",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 4,
            "fileName": "scene-4-4.mp3",
            "path": "public/audio/stories/scene-4-4.mp3",
            "text": "ورسم زهرة ملونة فيها أحمر وأصفر وأخضر.",
            "ttsText": "وَرَسَمَ زَهْرَةً مُلَوَّنَةً فِيهَا أَحمرُ وَأَصْفَرُ وَأَخْضَرُ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-05",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 5,
            "fileName": "scene-4-5.mp3",
            "path": "public/audio/stories/scene-4-5.mp3",
            "text": "أراد كريم أن يمسح خطأ ولم يجد الممحاة، فقال لصديقه طارق: أعطني الممحاة من فضلك.",
            "ttsText": "أَرَادَ كَرِيمُ أَنْ يَمْسَحَ خَطَأً، وَلَمْ يَجِدِ الْمِمْحَاةَ، فَقَالَ لِصَدِيقِهِ طَارِقٍ: أَعْطِنِي الْمِمْحَاةَ مِنْ فَضْلِكَ.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-06",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 6,
            "fileName": "scene-4-6.mp3",
            "path": "public/audio/stories/scene-4-6.mp3",
            "text": "فقال له طارق: هذه هي، تفضل. ابتسم كريم وقال: شكرًا.",
            "ttsText": "فَقَالَ لَهُ طَارِقٌ: هَذِهِ هِيَ، تَفَضَّلْ. اِبْتَسَمَ كَرِيمُ وَقَالَ: شُكْرًا.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-07",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 7,
            "fileName": "scene-4-7.mp3",
            "path": "public/audio/stories/scene-4-7.mp3",
            "text": "نظر كريم إلى لوحته وهو مسرور، وقال: انظري يا معلمتي، لقد رسمت زهرة جميلة.",
            "ttsText": "نَظَرَ كَرِيمُ إِلَى لَوْحَتِهِ وَهُوَ مَسْرُورٌ، وَقَالَ: اُنْظُرِي يَا مُعَلِّمَتِي، لَقَدْ رَسَمْتُ زَهْرَةً جَمِيلَةً.",
            "voice": "ar-EG-ShakirNeural"
        },
        {
            "id": "story-04-scene-08",
            "kind": "storyScene",
            "group": "story-04",
            "scene": 8,
            "fileName": "scene-4-8.mp3",
            "path": "public/audio/stories/scene-4-8.mp3",
            "text": "قالت المعلمة: أحسنت، إنها رسمة جميلة.",
            "ttsText": "قَالَتِ الْمُعَلِّمَةُ: أَحْسَنْتَ، إِنَّهَا رَسْمَةٌ جَمِيلَةٌ.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-001",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-001.mp3",
            "path": "public/audio/ui/phrase-001.mp3",
            "text": "أهلاً بكم في رحلة الوعي الصوتي! هيا نلعب ونتعلم معاً.",
            "ttsText": "أَهْلًا بِكُمْ فِي رِحْلَةِ الْوَعْيِ الصَّوْتِي! هَيَّا نَلْعَبْ وَنَتَعَلَّمْ مَعًا.",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-002",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-002.mp3",
            "path": "public/audio/ui/phrase-002.mp3",
            "text": "جاهز للمغامرة اليوم؟",
            "ttsText": "جَاهِزٌ لِلْمُغَامَرَةِ الْيَوْم؟",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-003",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-003.mp3",
            "path": "public/audio/ui/phrase-003.mp3",
            "text": "استمر في رحلتك لتعلم الأصوات والحروف واكتشاف المكافآت الرائعة!",
            "ttsText": "اِسْتَمِرَّ فِي رِحْلَتِكَ لِتَعَلُّمِ الْأَصْوَاتِ وَالْحُرُوفِ وَاكْتِشَافِ الْمُكَافَآتِ الرَّائِعَة!",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-004",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-004.mp3",
            "path": "public/audio/ui/phrase-004.mp3",
            "text": "اختر صديقك المفضل ليرافقك في رحلة التعلم!",
            "ttsText": "اِخْتَرْ صَدِيقَكَ الْمُفَضَّلَ لِيُرَافِقَكَ فِي رِحْلَةِ التَّعَلُّم!",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-005",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-005.mp3",
            "path": "public/audio/ui/phrase-005.mp3",
            "text": "خريطة الرحلة",
            "ttsText": "خَرِيطَةُ الرِّحْلَة",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-006",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-006.mp3",
            "path": "public/audio/ui/phrase-006.mp3",
            "text": "الكنز الكبير!",
            "ttsText": "الْكَنْزُ الْكَبِير!",
            "voice": "ar-SA-ZariyahNeural"
        },
        {
            "id": "phrase-007",
            "kind": "phrase",
            "group": "ui",
            "fileName": "phrase-007.mp3",
            "path": "public/audio/ui/phrase-007.mp3",
