# MonsterASP.NET Environment Variables
# Copy this file to .env and customize for your deployment

NODE_ENV=production

# IMPORTANT: Do NOT set PORT on MonsterASP unless support explicitly requires it.
# IISNode provides PORT as a named pipe automatically.
# PORT=

# Database - SQLite file in App_Data folder (persistent on Monster)
DATABASE_URL=file:./App_Data/db.sqlite

# Frontend API URL - leave empty to use same domain
VITE_API_BASE_URL=

# Authentication - CHANGE THIS TO A SECRET STRING!
AUTH_TOKEN_SECRET=change-this-to-a-random-string-min-32-characters

# CORS - set to your domain in production
CORS_ORIGIN=*
